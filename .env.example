# Host paths must be absolute Linux paths.
MODEL_PATH=/srv/models/GLM-5.2-MXFP8-NVFP4-NF3-Hybrid
HF_CACHE_PATH=/srv/cache/huggingface
RUNTIME_CACHE_PATH=/srv/cache/glm52-v17-lmcache
RUNTIME_TMP_PATH=/srv/tmp/glm52-v17-lmcache-ckv-gather

# Local image tag. Replace with the published versioned tag after release.
GLM52_IMAGE=glm52-v17-lmcache-ckv-gather:0.1.0-exp.1
RELEASE_VERSION=0.1.0-exp.1

PORT=5001
LMCACHE_HTTP_PORT=8088
LMCACHE_L1_GB=48
CONTAINER_MEMORY_LIMIT=110g

